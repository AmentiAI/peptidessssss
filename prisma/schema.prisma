generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Product {
  id               String   @id @default(cuid())
  name             String
  slug             String   @unique
  price            Float?
  priceFormatted   String?
  imageUrl         String?
  productUrl       String
  description      String
  shortDescription String?
  categories       String[]
  isFeatured       Boolean  @default(false)
  badge            String?
  isBundle         Boolean  @default(false)
  isInStock        Boolean  @default(true)
  sortOrder        Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Category {
  id              String   @id @default(cuid())
  name            String   @unique
  slug            String   @unique
  icon            String?
  color           String?
  description     String?
  heroDescription String?
  seoDescription  String?
  stats           Json?
  content         String?
  faq             Json?
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model BlogPost {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  description String
  content     String
  date        DateTime
  author      String   @default("PeptideLab Research Team")
  category    String
  imageUrl    String?
  tags        String[]
  isFeatured  Boolean  @default(false)
  readTime    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Guide {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  description String
  content     String
  date        DateTime
  author      String   @default("PeptideLab Research Team")
  imageUrl    String?
  readTime    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
