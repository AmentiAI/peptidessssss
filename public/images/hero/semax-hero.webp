  <circle cx="1500" cy="340" r="400" fill="#10b981" opacity="0.04"/>
  <circle cx="1650" cy="200" r="250" fill="#7c3aed" opacity="0.04"/>
  <text x="100" y="320" font-family="system-ui,sans-serif" font-size="90" font-weight="900" fill="white" opacity="0.9">Semax</text>
